# ============================================
# Quota Dashboard — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your keys.
# Never commit .env.local to version control.

# ── Alert thresholds (optional) ──────────────
# Fractions in (0, 1]. Drive warning/critical status across cards, bars, and
# the summary strip. NEXT_PUBLIC_ so server + client stay consistent.
# Defaults: warning 0.7, critical 0.9. Over-limit is always critical.
# NEXT_PUBLIC_ALERT_WARNING_PCT=0.7
# NEXT_PUBLIC_ALERT_CRITICAL_PCT=0.9

# ── Lucidya CXM ──────────────────────────────

# X (Twitter) API
CXM_X_BEARER_TOKEN=
CXM_X_APP_MAP={"APP_ID_1":"Social Listening","APP_ID_2":"OmniChannel"}

# Netfeedr — each product has its own API key
# All hit the same endpoint: GET https://api.netfeedr.com/v26.4.1/usage.json?apikey=KEY
CXM_NETFEEDR_CHANNELS_API_KEY=
CXM_NETFEEDR_SEARCH_API_KEY=
CXM_NETFEEDR_UPDATER_API_KEY=

# ── Site ─────────────────────────────────────

# X (Twitter) API
SITE_X_BEARER_TOKEN=
SITE_X_APP_MAP={"APP_ID_1":"Site Listener"}

# Netfeedr
SITE_NETFEEDR_CHANNELS_API_KEY=
SITE_NETFEEDR_SEARCH_API_KEY=
SITE_NETFEEDR_UPDATER_API_KEY=
