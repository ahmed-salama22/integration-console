# ============================================
# Quota Dashboard — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your keys.
# Never commit .env.local to version control.

# ── Alert thresholds (optional) ──────────────
# Fractions in (0, 1]. Drive warning/critical status across cards, bars, and
# the summary strip. NEXT_PUBLIC_ so server + client stay consistent.
# Defaults: warning 0.6, critical 0.8. Over-limit is always critical.
# NEXT_PUBLIC_ALERT_WARNING_PCT=0.6
# NEXT_PUBLIC_ALERT_CRITICAL_PCT=0.8

# ── AI Services (LiteLLM proxies) ────────────
# Two self-hosted proxies, one per deployment environment. Each fronts all AI
# model providers for that env. Key may be the master key or a virtual key
# (virtual keys typically can't read the admin /health endpoint).
LITELLM_STAGING_PROXY_URL=
LITELLM_STAGING_API_KEY=
LITELLM_PROD_PROXY_URL=
LITELLM_PROD_API_KEY=
# AI Services shows built-in SAMPLE data until this is set to 1. Flip to 1 once
# both proxies are reachable with working keys to query the live proxy instead.
LITELLM_LIVE=

# ── Lucidya CXM ──────────────────────────────

# X (Twitter) API
CXM_X_BEARER_TOKEN=
CXM_X_APP_MAP={"APP_ID_1":"Social Listening","APP_ID_2":"OmniChannel"}

# Netfeedr — each product has its own API key
# All hit the same endpoint: GET https://api.netfeedr.com/v26.4.1/usage.json?apikey=KEY
CXM_NETFEEDR_CHANNELS_API_KEY=
CXM_NETFEEDR_SEARCH_API_KEY=
CXM_NETFEEDR_UPDATER_API_KEY=

# eMedia (TV & Radio) — fixed-subscription channel catalogue.
# HTTP Basic auth. URL defaults to https://dart.emediamonitor.net/api/channels.
CXM_EMEDIA_USERNAME=
CXM_EMEDIA_PASSWORD=
# CXM_EMEDIA_API_URL=   # optional override

# ── Site ─────────────────────────────────────

# X (Twitter) API
SITE_X_BEARER_TOKEN=
SITE_X_APP_MAP={"APP_ID_1":"Site Listener"}

# Netfeedr
SITE_NETFEEDR_CHANNELS_API_KEY=
SITE_NETFEEDR_SEARCH_API_KEY=
SITE_NETFEEDR_UPDATER_API_KEY=

# eMedia (TV & Radio)
SITE_EMEDIA_USERNAME=
SITE_EMEDIA_PASSWORD=
# SITE_EMEDIA_API_URL=   # optional override
